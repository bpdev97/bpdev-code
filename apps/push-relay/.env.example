# Public Apple identifiers
APNS_TEAM_ID=YOUR_TEAM_ID
APNS_KEY_ID=YOUR_KEY_ID
APNS_BUNDLE_ID=com.bpdev97.t3code.ios
APNS_ENVIRONMENT=production

# Bind the published port only to this Linux host's Tailscale address.
TAILNET_BIND_ADDRESS=100.x.y.z

# Host paths; neither file is copied into the image.
APNS_PRIVATE_KEY_PATH=./secrets/AuthKey_KEYID.p8
RELAY_PASSWORD_PATH=./secrets/relay-password
